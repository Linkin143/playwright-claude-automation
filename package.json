{
  "name": "playwright-claude-automation",
  "version": "1.0.0",
  "description": "Automated Playwright testing with Claude AI",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "bridge": "cd bridge-service && npm start",
    "allure:generate": "allure generate allure-results -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results"
  },
  "keywords": [
    "playwright",
    "automation",
    "claude",
    "testing"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "allure": "^3.4.0",
    "allure-playwright": "^3.7.1",
    "dotenv": "^17.4.1",
    "nodemailer": "^8.0.4"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
